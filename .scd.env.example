# SCD Configuration
# OpenAI-compatible API settings (works with OpenAI, OneAPI, NewAPI, LiteLLM,
# vLLM, Ollama, and similar self-hosted gateways).
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Optional tuning
# RPS=3.0
# MATCH_BATCH_SIZE=40

# Endpoint capability toggles. Leave off if unsure; the client auto-downgrades
# on 400 errors if a flag is not supported.
# USE_JSON_MODE=false
# PARALLEL_TOOL_CALLS=false
